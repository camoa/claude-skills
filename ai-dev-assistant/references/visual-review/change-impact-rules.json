{
  "schema_version": "1.0",
  "rules": [
    { "glob": "**/*.css",  "gates": ["visual_regression"] },
    { "glob": "**/*.scss", "gates": ["visual_regression"] },
    { "glob": "**/*.sass", "gates": ["visual_regression"] },
    { "glob": "**/*.less", "gates": ["visual_regression"] },
    { "glob": "**/*.js",   "gates": ["e2e", "visual_regression"] },
    { "glob": "**/*.mjs",  "gates": ["e2e", "visual_regression"] },
    { "glob": "**/*.cjs",  "gates": ["e2e", "visual_regression"] },
    { "glob": "**/*.ts",   "gates": ["e2e", "visual_regression"] },
    { "glob": "**/*.html", "gates": ["e2e", "visual_regression"] },
    { "glob": "**/*.htm",  "gates": ["e2e", "visual_regression"] }
  ],
  "default_gates": []
}
