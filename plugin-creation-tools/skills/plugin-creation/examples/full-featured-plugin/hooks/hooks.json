{
  "description": "Example hooks demonstrating cross-platform setup",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" session-start.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" post-edit.sh",
            "timeout": 30
          }
        ]
      }
    ],

    "_comment_if_field": "The 'if' field pre-filters tool-event handlers before spawn — avoids running the hook on every Bash call.",
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(rm *)",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" guard-rm.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
